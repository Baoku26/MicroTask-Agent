{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "rootDir": "."
  },
  "include": ["contracts/scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "artifacts", "cache"]
}
